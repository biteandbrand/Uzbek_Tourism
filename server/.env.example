# Bu dosyayı .env olarak kopyalayıp gerçek değerleri girin (repoya .env YAZMAYIN).
# Railway'de bu değerler proje "Variables" sekmesine girilir.

# Postgres bağlantısı (Railway managed Postgres "DATABASE_URL" sağlar)
DATABASE_URL=

# HTTP portu (Railway PORT'u otomatik enjekte eder; yerelde 8080)
PORT=8080

# Yönetim/ingestion için (ileride admin endpoint eklenirse)
ADMIN_TOKEN=

# Cloudflare R2 (S3 uyumlu) — medya yalnızca buradan akar
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=        # ör. https://media.uztour.example

# TTS sağlayıcısı (boşsa ingest kuru çalışır)
TTS_PROVIDER=              # ör. elevenlabs
TTS_API_KEY=
TTS_VOICE_ID=             # opsiyonel; ElevenLabs ses kimliği
